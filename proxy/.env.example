# 프록시 기기(라즈베리파이) 전용 환경변수 템플릿
# cp .env.example .env 후 실제 값을 채운다. .env 는 커밋하지 않는다.

# V-World 인증키 (data.go.kr / vworld.kr 오픈API 키) — 이 기기에만 둔다
VWORLD_API_KEY=

# 백엔드와 공유하는 시크릿 토큰. 아래로 생성:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# 같은 값을 Railway 백엔드의 VWORLD_PROXY_TOKEN 에도 등록한다.
VWORLD_PROXY_TOKEN=
