# 팜바톤 환경변수 템플릿
# 이 파일을 복사해 .env 로 만들고 실제 값을 채운다.  cp .env.example .env
# .env 는 절대 커밋하지 않는다 (.gitignore 처리됨).

# ── Supabase (PostgreSQL + PostGIS) ──────────────
# Dashboard > Project Settings > Database / API 에서 확인
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# psql / ETL 직접 연결용 (Connection string, Session pooler 권장)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ── V-World (지오코딩 · 공시지가 · 배경지도) ──────
# vworld.kr > 오픈API > 인증키
VWORLD_API_KEY=

# ── V-World 국내 우회 프록시 (선택) ──────────────
# 해외 클라우드 IP 차단 우회용. 국내 기기에서 proxy/ 를 띄우고 Tailscale
# Funnel 등으로 노출한 주소를 적는다. 설정 시 V-World 를 프록시 경유로 호출
# (이때 VWORLD_API_KEY 는 프록시 기기에만 두면 됨). 미설정 시 기존 직접호출.
# 자세한 셋업은 proxy/README.md 참고.
VWORLD_PROXY_URL=
VWORLD_PROXY_TOKEN=

# ── 팜맵 (data.go.kr B552895) ────────────────────
# 공공데이터포털 활용신청 후 발급 (Encoding/Decoding 키 구분 주의)
FARMMAP_SERVICE_KEY=

# ── KAMIS (농산물 시세) ──────────────────────────
# kamis.or.kr > OpenAPI
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# ── 카카오 로컬 (지오코딩 백업) ──────────────────
KAKAO_REST_API_KEY=

# ── Claude API (설명문 생성용, 수치계산엔 미사용) ─
ANTHROPIC_API_KEY=

# ── 농가 로그인 (JWT 서명 키) ─────────────────────
# 외부 발급 불필요, 아래 한 줄로 직접 생성:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── 앱 설정 ──────────────────────────────────────
APP_ENV=development

# ── 배포 (Railway 환경변수로 설정) ───────────────
# CORS 허용 오리진 (콤마 구분, Vercel 배포 URL)
ALLOWED_ORIGINS=https://farmbaton.vercel.app

# ── 프론트엔드 (Vercel 환경변수로 설정) ──────────
# 배포된 백엔드 URL (Railway)
VITE_API_BASE_URL=https://farmbaton-backend.railway.app/api
# 농가등록 지도 배경(항공영상, V-World WMTS) — 브라우저에서 직접 호출되므로
# 노출돼도 되는 키만 사용. VWORLD_API_KEY와 값은 같아도 되나, vworld.kr
# 콘솔에서 이 키의 "사용 도메인"에 로컬(localhost)·배포 도메인을 등록해야
# 실제로 타일이 뜬다(미등록 시 조용히 실패하지 않고 XML 에러 응답).
# 미설정 시 OSM 배경지도로 자동 폴백(로컬 개발 시 생략 가능).
VITE_VWORLD_API_KEY=
